  const el = document.getElementById('mkt-checklist');
  if (!el) return;
  // Group by category
  const cats = [...new Set(MKT_ACTIONS.map(a => a.cat))];
  const stars = n => '★'.repeat(n) + '☆'.repeat(5-n);
  const recColor = r => r.includes('強烈')?'var(--green)':r.includes('謹慎')?'var(--red)':'var(--yellow)';
  const tierBg = ['A','B','C'].map(t=>`<span style="font-size:.6rem;padding:1px 5px;border-radius:8px;background:rgba(108,99,255,.15);color:var(--accent);">${t}</span>`);

  el.innerHTML = cats.map(cat => {
    const items = MKT_ACTIONS.filter(a => a.cat === cat && (activeTier === 'all' || a.tiers.includes(activeTier))).sort((a,b) => a.budgetMin - b.budgetMin);
    if (!items.length) return '';
    return `
      <div style="margin-bottom:12px;">
        <div class="sec-lbl" style="margin-bottom:5px;">${cat}</div>
        ${items.map(a => `
          <div class="ing-block" id="mkt-blk-${a.id}" style="display:flex;align-items:flex-start;gap:10px;padding:10px 12px;">
            <input type="checkbox" id="mkt-ck-${a.id}" style="margin-top:3px;width:16px;height:16px;accent-color:var(--green);cursor:pointer;" onchange="updateMktBudget()">
            <div style="flex:1;">
              <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-bottom:3px;">
                <label for="mkt-ck-${a.id}" style="font-size:.84rem;font-weight:700;cursor:pointer;">${a.title}</label>
                <span style="font-size:.68rem;padding:1px 6px;border-radius:8px;background:${recColor(a.rec)}22;color:${recColor(a.rec)};font-weight:700;">${a.rec}</span>
                ${a.tiers.map(t=>`<span style="font-size:.58rem;padding:1px 5px;border-radius:6px;background:rgba(108,99,255,.12);color:var(--accent);">${t}</span>`).join('')}
              </div>
              <div style="font-size:.73rem;color:var(--t2);margin-bottom:5px;line-height:1.6;">${a.desc}</div>
              <div style="display:flex;gap:12px;align-items:center;">
                <span style="font-size:.7rem;color:var(--yellow);">${stars(a.priority)}</span>
                <span style="font-size:.7rem;color:var(--t2);">預算：${a.budgetMin === 0 ? '申請制' : a.budgetMin+'–'+a.budgetMax+'萬'}</span>
              </div>
            </div>
          </div>
        `).join('')}
      </div>`;
  }).join('');
  updateMktBudget();
}

function updateMktBudget() {
  let total = 0, count = 0;
  MKT_ACTIONS.forEach(a => {
    const ck = document.getElementById('mkt-ck-'+a.id);
    if (ck && ck.checked) { total += (a.budgetMin + a.budgetMax) / 2; count++; }
  });
  const el = document.getElementById('mkt-budget-sum');
  const cel = document.getElementById('mkt-checked-count');
  if (el) el.textContent = total === 0 ? '0 萬' : '~' + total.toFixed(0) + ' 萬';
  if (cel) cel.textContent = count > 0 ? `（已勾選 ${count} 項）` : '';
}

function setTier(t) {
  activeTier = t;
  ['all','A','B','C'].forEach(id => {
    const btn = document.getElementById('tier-'+id);
    if (btn) btn.classList.toggle('active', id === t);
  });
  renderChecklist();
}

function renderPlan(p) {
  const plan = PLANS[p];
  const el = document.getElementById('plan-display');
  if (!el || !plan) return;
  const totalAmt = plan.items.reduce((s,i)=>s+i.amt, 0);
  el.innerHTML = `
    <div style="padding:12px 16px;background:rgba(0,0,0,.15);border-radius:8px;border-left:4px solid ${plan.color};margin-bottom:12px;">
      <div style="font-size:.72rem;color:${plan.color};font-weight:700;margin-bottom:4px;">總預算：${plan.budget}</div>
      <div style="font-size:.84rem;font-weight:700;margin-bottom:2px;">核心戰略</div>
      <div style="font-size:.8rem;color:var(--t2);">${plan.strategy}</div>
    </div>
    <div style="margin-bottom:12px;">
      <div class="sec-lbl">預算分配</div>
      ${plan.items.map(item => `
        <div style="margin-bottom:7px;">
          <div style="display:flex;justify-content:space-between;font-size:.78rem;margin-bottom:3px;">
            <span>${item.name}</span>
            <span style="font-weight:700;color:${plan.color};">${item.amt} 萬 (${item.pct}%)</span>
          </div>
          <div style="height:7px;background:var(--border);border-radius:4px;">
            <div style="height:100%;width:${item.pct}%;background:${plan.color};border-radius:4px;opacity:.8;"></div>
          </div>
        </div>
      `).join('')}
      <div style="display:flex;justify-content:space-between;font-size:.79rem;padding:7px 0;border-top:1px solid var(--border);margin-top:5px;font-weight:700;">
        <span>總計</span><span style="color:${plan.color};">${totalAmt} 萬</span>
      </div>
    </div>
    <div style="padding:10px 14px;background:rgba(34,211,160,.08);border:1px solid rgba(34,211,160,.25);border-radius:8px;font-size:.8rem;">
      <span style="color:var(--green);font-weight:700;">📈 預期成效：</span>${plan.outcome}
    </div>`;
}

function showPlan(p) {
  activePlan = p;
  ['A','B','C'].forEach(id => {
    const btn = document.getElementById('plan-'+id);
    if (btn) btn.classList.toggle('active', id === p);
  });
  renderPlan(p);
}
</script>

<script>
// ══ Reference data ══════════════════════════════════════════
const ING_REF = {
  wheat:    { name:'小麥蛋白(IWP)',       protein:82.8, fat:0.5,  fiber:0.7,  sugar:0.3, color:'#6c63ff' },
  soy:      { name:'炒熟黃豆粉',          protein:36,   fat:18,   fiber:9.3,  sugar:3.0, color:'#22d3a0' },
  black:    { name:'黑豆粉',              protein:34,   fat:1.5,  fiber:16,   sugar:2.0, color:'#f7971e' },
  buck:     { name:'熟蕎麥粉',            protein:13,   fat:3.0,  fiber:10,   sugar:2.0, color:'#ff5c5c' },
  pea:      { name:'豌豆粉',              protein:22,   fat:2.0,  fiber:15,   sugar:3.0, color:'#ffd93d' },
  collagen: { name:'膠原蛋白 Verisol P',  protein:91,   fat:0,    fiber:0,    sugar:0,   color:'#b478ff' },
  other:    { name:'其他',                protein:15,   fat:5.0,  fiber:5,    sugar:2.0, color:'#9aa0b4' },
};
const FLOUR_REF = { protein:12, fat:1.5, fiber:2.5, sugar:0.5 }; // per 100g
const F312_REF  = { protein:5,  fat:0,   fiber:88,  sugar:0 };
const F7000_REF = { protein:0.5,fat:0,   fiber:88,  sugar:0 };

let sauces = new Set([1]);
let activeBoard = 1;

// ══ Helpers ═════════════════════════════════════════════════
const $ = id => document.getElementById(id);
const ckEn  = id => $(id).checked;
const slVal = id => +$(id).value;

function feeCalc(price) {
  const shopee = ckEn('ck-shopee') ? price * 0.125 : 0;
  const tax    = price / 1.05 * 0.05;
  const ads    = ckEn('ck-ads')    ? price * 0.22  : 0;
  return { shopee, tax, ads, net: price - shopee - tax - ads };
}

function feeCalcB2(price) {
  const shopee = ckEn('ck-shopee-b2') ? price * 0.125 : 0;
  const tax    = price / 1.05 * 0.05;
  const ads    = ckEn('ck-ads-b2')    ? price * 0.22  : 0;
  return { shopee, tax, ads, net: price - shopee - tax - ads };
}

function toggleIng(id) {
  const en = ckEn('en-' + id);
  $('blk-' + id).classList.toggle('disabled', !en);
  $(id + '-r').disabled = !en;
  $(id + '-p').disabled = !en;
  if (id === 'other') $('other-prot').disabled = !en;
  if (!en) $(id + '-r').value = 0;
  calc();
}

function toggleFiber(type) {
  const box = $('fbox-' + type);
  const en  = ckEn('en-' + type);
  box.classList.toggle('active', en);
  box.classList.toggle('disabled', !en);
  $('amt-' + type).disabled = !en;
  // price slider id pattern: '312f-p' / '7000-p'
  const pSlider = $(type + '-p');
  if (pSlider) pSlider.disabled = !en;
  calc();
}

function toggleSauce(id) {
  const btn = $('s' + id);
  if (sauces.has(id)) { sauces.delete(id); btn.classList.remove('active'); }
  else                { sauces.add(id);    btn.classList.add('active'); }
}

function onFlourTypeChange() {
  const val = $('flour-type').value;
  $('custom-flour-row').style.display = val === 'custom' ? '' : 'none';
  calc();
}

function getFlourProtein() {
  const val = $('flour-type').value;
  if (val === 'custom') {
    $('sv-flour-p-f').textContent = slVal('flour-p-f').toFixed(1) + '%';
    return slVal('flour-p-f');
  }
  return +val;
}

// ══ Pre-mix composition ════════════════════════════════════
function getPremixData() {
  const IDS = ['wheat','soy','black','buck','pea','collagen','other'];
  let totalR = 0, costSum = 0;
  let pmProt=0, pmFat=0, pmFiber=0, pmSugar=0;
  const grams = {};

  IDS.forEach(id => {
    const en = ckEn('en-' + id);
    const r  = en ? slVal(id + '-r') : 0;
    const p  = slVal(id + '-p');
    grams[id] = r; // ratio (we'll convert later)

    $('sv-' + id + '-r').textContent = r + '%';
    $('sv-' + id + '-p').textContent = p + (id==='buck'?'元/kg':' 元/kg');

    if (en && r > 0) {
      const ref = id === 'other'
        ? { protein: slVal('other-prot'), fat:5, fiber:5, sugar:2 }
        : ING_REF[id];
      totalR   += r;
      costSum  += r * p; // yuan per kg * ratio
      pmProt   += r * ref.protein;
      pmFat    += r * ref.fat;
      pmFiber  += r * ref.fiber;
      pmSugar  += r * ref.sugar;
    }
  });
  $('sv-other-prot').textContent = slVal('other-prot') + '%';

  const eff = totalR || 1;
  return {
    totalRatio: totalR,
    costPerKg:  totalR > 0 ? costSum / eff : 0,
    prot:  pmProt  / eff,
    fat:   pmFat   / eff,
    fiber: pmFiber / eff,
    sugar: pmSugar / eff,
    ratios: grams,
  };
}

// ══ Formula solver (1 unknown: pre-mix total P) ═════════════
function solveFormula(pm, flourProt, batchF, saltPct, waterRatio, protTarget, C312, C7000) {
  const F   = batchF;
  const S   = F * saltPct / 100;
  const C   = C312 + C7000;
  const wr  = waterRatio / 100;
  const k   = protTarget / 100 * (1 + wr); // protein fraction needed

  // flour prot contribution
  const fixedProt = F * flourProt / 100
    + C312 * F312_REF.protein / 100
    + C7000 * F7000_REF.protein / 100;

  // P * pm.prot/100 = k*(F + P + C + S) - fixedProt
  // P * (pm.prot/100 - k) = k*(F + C + S) - fixedProt
  const denom = pm.prot / 100 - k;
  if (Math.abs(denom) < 1e-6) return null; // singular
  const P = (k * (F + C + S) - fixedProt) / denom;
  return P;
}

// ══ Render formula table ════════════════════════════════════
function renderFormulaTable(pm, flourProt, batchF, saltPct, waterRatio, protTarget, C312g, C7000g) {
  const F  = batchF;
  const S  = F * saltPct / 100;
  const C312  = ckEn('en-312f') ? C312g  : 0;
  const C7000 = ckEn('en-7000') ? C7000g : 0;
  const C = C312 + C7000;

  const P = solveFormula(pm, flourProt, F, saltPct, waterRatio, protTarget, C312, C7000);
  $('formula-error').style.display = (P === null) ? '' : 'none';
  $('formula-neg').style.display   = (P !== null && P < 0) ? '' : 'none';
  if (P === null || P < 0) {
    $('formula-tbody').innerHTML = '';
    return null;
  }

  const wr = waterRatio / 100;
  const D  = F + P + C + S;
  const W  = D * wr;
  const T  = D + W;

  // Build rows
  const rows = [];
  const addRow = (cls, name, g, prot_pct, fat_pct, fiber_pct, sugar_pct, fn) => {
    const baker = (g / F * 100);
    const total = (g / T * 100);
    const protG  = g * prot_pct  / 100;
    const fiberG = g * fiber_pct / 100;
    rows.push({ cls, name, g, baker, total, protG, fiberG, fn });
  };

  const flEntry = FLOUR_REF;
  addRow('flour-row', `台灣麵粉 (蛋白${flourProt}%)`, F, flourProt, flEntry.fat, flEntry.fiber, flEntry.sugar, '基礎多醣基質');

  // Pre-mix ingredients
  const IDS = ['wheat','soy','black','buck','pea','collagen','other'];
  IDS.forEach(id => {
    const en = ckEn('en-' + id);
    const r  = slVal(id + '-r');
    if (!en || r === 0) return;
    const g_ing = P * r / (pm.totalRatio || 1);
    const ref   = id === 'other'
      ? { protein: slVal('other-prot'), fat:5, fiber:5, sugar:2 }
      : ING_REF[id];
    const displayName = id === 'other' ? ($('other-name').value || '自訂') : ING_REF[id].name;
    addRow('ing-row', displayName, g_ing, ref.protein, ref.fat, ref.fiber, ref.sugar, '預拌粉成分');
  });

  if (C312 > 0) addRow('fiber-row', 'JRS VITACEL 312F', C312, F312_REF.protein, 0, F312_REF.fiber, 0, '不溶性纖維骨架');
  if (C7000 > 0) addRow('fiber-row', 'CEAMSA 7000',      C7000, F7000_REF.protein, 0, F7000_REF.fiber, 0, '細膩纖維補充');
  if (S > 0) addRow('salt-row', '鹽', S, 0, 0, 0, 0, '調味・鈉來源');
  addRow('water-row', '配方水', W, 0, 0, 0, 0, `加水比例 ${waterRatio}%`);

  let totalProt = 0, totalFiber = 0;
  let html = rows.map(r => {
    totalProt  += r.protG;
    totalFiber += r.fiberG;
    return `<tr class="${r.cls}">
      <td>${r.name}<div style="font-size:.64rem;color:var(--t2);">${r.fn}</div></td>
      <td class="gram-num">${r.g.toFixed(1)}</td>
      <td>${r.baker.toFixed(2)}%</td>
      <td>${r.total.toFixed(2)}%</td>
      <td>${r.protG.toFixed(1)}</td>
      <td>${r.fiberG.toFixed(1)}</td>
    </tr>`;
  }).join('');

  const actualProt  = totalProt  / T * 100;
  const actualFiber = totalFiber / T * 100;
  const sodiumMg    = S * 394;

  html += `<tr class="total-row">
    <td>▶ 總濕麵糰重量</td>
    <td class="gram-num">${T.toFixed(0)}</td>
    <td>—</td>
    <td>100.00%</td>
    <td>${totalProt.toFixed(1)}</td>
    <td>${totalFiber.toFixed(1)}</td>
  </tr>`;
  $('formula-tbody').innerHTML = html;

  // QC bar (new card-style: inner val spans)
  const pDiff = Math.abs(actualProt - protTarget);
  const pClass = pDiff < 0.2 ? 'qc-ok' : pDiff < 0.5 ? 'qc-warn' : 'qc-bad';
  const qcProtValEl = $('qc-prot-val');
  if (qcProtValEl) {
    qcProtValEl.textContent = `${actualProt.toFixed(2)}% (目標${protTarget}%)`;
    qcProtValEl.className = 'qc-big ' + pClass;
  } else {
    $('qc-prot').className = `qc-item ${pClass}`;
    $('qc-prot').textContent = `蛋白質: ${actualProt.toFixed(2)}%`;
  }
  const qcFiberValEl = $('qc-fiber-val');
  if (qcFiberValEl) { qcFiberValEl.textContent = `${actualFiber.toFixed(2)}%`; qcFiberValEl.className = 'qc-big qc-ok'; }
  else $('qc-fiber').textContent = `纖維: ${actualFiber.toFixed(2)}%`;
  const qcSodiumValEl = $('qc-sodium-val');
  if (qcSodiumValEl) { qcSodiumValEl.textContent = `${sodiumMg.toFixed(0)} mg`; qcSodiumValEl.className = 'qc-big'; }
  else $('qc-sodium').textContent = `鈉: ${sodiumMg.toFixed(0)}mg/100g乾麵`;
  const qcWetValEl = $('qc-wet-val');
  if (qcWetValEl) { qcWetValEl.textContent = `${T.toFixed(0)} g`; qcWetValEl.className = 'qc-big'; }
  else $('qc-wet').textContent = `濕麵糰: ${T.toFixed(0)}g/批`;

  // 動態加水警告（WAI 實測校準值）
  // 麵粉 WAI ≈ 0.55 | IWP/大豆蛋白粉 WAI ≈ 0.80 | 柑橘/木質纖維 WAI ≈ 3.5
  const idealWater = F * 0.55 + P * 0.80 + C * 3.5;
  const hydrationRatio = W / idealWater;
  // 建議加水比例（讓 W 達到 idealWater 的 95%）
  const suggestedWR = Math.ceil(idealWater * 0.95 / (F + P + C + S) * 100);
  const qcHydEl = $('qc-hydration');
  if (hydrationRatio < 0.80) {
    qcHydEl.className = 'qc-item qc-bad';
    qcHydEl.textContent = `⚠ 游離水嚴重不足（${(hydrationRatio*100).toFixed(0)}%）─ 建議加水比例調至 ${suggestedWR}% 以上`;
  } else if (hydrationRatio < 0.95) {
    qcHydEl.className = 'qc-item qc-warn';
    qcHydEl.textContent = `💧 加水偏低（${(hydrationRatio*100).toFixed(0)}%）─ 建議加水比例拉至 ${suggestedWR}%`;
  } else {
    qcHydEl.className = 'qc-item qc-ok';
    qcHydEl.textContent = `💧 加水充足（${(hydrationRatio*100).toFixed(0)}%，實際${W.toFixed(0)}g / 理論基準${idealWater.toFixed(0)}g）`;
  }

  return { P, C312, C7000, S, W, T, actualProt, actualFiber, sodiumMg, totalProt, totalFiber };
}

// ══ Main calc ════════════════════════════════════════════════
function calc() {
  const pm = getPremixData();

  // Ratio bar
  const rMax = Math.max(pm.totalRatio, 100);
  ['wheat','soy','black','buck','pea','collagen','other'].forEach(id => {
    $('rb-' + id).style.width = (pm.ratios[id] / rMax * 100) + '%';
  });
  $('rb-rest').style.width = (Math.max(0, 100 - pm.totalRatio) / rMax * 100) + '%';
  const rt = $('ratio-total');
  if (Math.abs(pm.totalRatio - 100) <= 2) rt.innerHTML = `<span style="color:var(--green)">✓ 預拌粉比例總和：${pm.totalRatio}%（標準配比）</span>`;
  else if (pm.totalRatio > 100) rt.innerHTML = `<span style="color:var(--red)">⚠ 總和：${pm.totalRatio}%（超出100%，請降低某項比例）</span>`;
  else rt.innerHTML = `<span style="color:var(--t2)">預拌粉比例總和：${pm.totalRatio}%（系統自動正規化，蛋白質%已按比例換算）</span>`;

  // Protein bar (recipe card)
  const pmRatio   = slVal('pm-ratio');
  const flourProt = getFlourProtein();
  const finalProt = (pmRatio / 100) * pm.prot + (1 - pmRatio / 100) * flourProt;
  $('premix-prot').textContent = pm.prot.toFixed(1) + '%';
  $('prot-fill').style.width = Math.min(100, finalProt / 40 * 100) + '%';
  $('pm-ratio-disp').textContent = pmRatio + '%';
  if (finalProt < 20) {
    $('prot-fill').style.background = 'var(--red)';
    $('prot-status').innerHTML = `<span style="color:var(--red)">⚠ ${finalProt.toFixed(1)}% 低於目標20%</span>`;
  } else if (finalProt <= 22) {
    $('prot-fill').style.background = 'var(--green)';
    $('prot-status').innerHTML = `<span style="color:var(--green)">✓ ${finalProt.toFixed(1)}% 達標 20–22%</span>`;
  } else {
    $('prot-fill').style.background = 'var(--yellow)';
    $('prot-status').innerHTML = `<span style="color:var(--yellow)">💡 ${finalProt.toFixed(1)}% 超過22%，可↓預拌比例</span>`;
  }

  // Slider displays
  $('sv-pm-ratio').textContent = pmRatio + '%';
  const ndBundles = +(($('nd-bundles') && $('nd-bundles').value) || 6);
  $('sv-nd-mfg').textContent   = slVal('nd-mfg') + ' 元/束';
  if ($('sv-nd-mfg-b1'))   $('sv-nd-mfg-b1').textContent   = slVal('nd-mfg').toFixed(1) + ' 元/包';
  if ($('sv-nd-mfg-pack')) $('sv-nd-mfg-pack').textContent = (slVal('nd-mfg') * ndBundles).toFixed(1) + ' 元/包';
  $('sv-pm-mfg').textContent   = slVal('pm-mfg') + ' 元/kg';
  $('sv-nd-bag').textContent   = slVal('nd-bag').toFixed(2) + ' 元';
  $('sv-sauce').textContent    = slVal('sauce-cost') + ' 元';
  $('sv-box').textContent      = slVal('box-cost') + ' 元/箱';
  $('sv-prot-target').textContent = slVal('prot-target') + '%';
  $('sv-water-ratio').textContent = slVal('water-ratio') + '%';
  // 蒸發濃縮倍數 & 預估乾麵蛋白
  const evapF = slVal('evap-factor');
  $('sv-evap-factor').textContent = evapF.toFixed(2) + '×';
  // 預設顯示簡單估算；若配方已解，下面 prot100 區段會覆蓋
  $('sv-dry-prot').textContent = '計算中…';
  window._dryProtTarget = slVal('prot-target') * evapF; // fallback
  // 纖維單價 displays
  $('sv-312f-p').textContent = slVal('312f-p') + ' 元/kg';
  $('sv-7000-p').textContent = slVal('7000-p') + ' 元/kg';
  $('sv-salt-f').textContent    = slVal('salt-f').toFixed(1) + '%';
  $('sv-312f-amt').textContent  = slVal('amt-312f').toFixed(1) + ' g';
  $('sv-7000-amt').textContent      = slVal('amt-7000').toFixed(1) + ' g';
  $('sv-collagen-r').textContent    = slVal('collagen-r') + '%';
  $('sv-collagen-p').textContent    = slVal('collagen-p') + '元/kg';

  // Formula table
  const batchF   = slVal('batch-flour') || 1000;
  const saltPct  = slVal('salt-f');
  const waterRatio = slVal('water-ratio');
  const protTarget = slVal('prot-target');
  const C312g    = ckEn('en-312f') ? slVal('amt-312f') : 0;
  const C7000g   = ckEn('en-7000') ? slVal('amt-7000') : 0;

  const formula = renderFormulaTable(pm, flourProt, batchF, saltPct, waterRatio, protTarget, C312g, C7000g);

  // Nutrition table (derive from formula, then scale to dry noodle)
  if (formula) {
    const { P, C312, C7000, S: saltG, T: wetT, actualProt, actualFiber, sodiumMg } = formula;
    // Wet dough ratios → dry noodle (lose water, ~12% moisture remains)
    // Dry noodle protein ≈ actualProt (wet basis protein scales up when water evaporates)
    // Wet protein% → dry protein%: prot_dry ≈ prot_wet / (1 - wet_water_fraction) * (1 - 0.12)
    const wr = slVal('water-ratio') / 100;
    const waterFrac = wr / (1 + wr); // fraction of total wet weight that is added water
    // Conservative estimate: dry noodle protein ≈ prot_wet / (1-waterFrac) * 0.88
    const scale = 0.88 / (1 - waterFrac); // 88% dry matter in finished noodle
    const prot100  = Math.min(35, actualProt * scale);
    const fiber100 = Math.min(20, actualFiber * scale);
    const fat100   = (pm.fat * P / 100 + batchF * 1.5 / 100) / (wetT / (1+wr)) * 0.88 * 100;
    const sodium100 = saltG * 394 / (wetT / (1+wr)) * 0.88 * 10; // mg per 100g dry
    // 台灣FDA法規：碳水化合物欄位 = 總碳水（含膳食纖維），不可先扣纖維
    const saltFrac  = (saltG / (wetT / (1 + wr)) * 0.88 * 100);
    const carb100   = Math.max(0, 88 - prot100 - fat100 - saltFrac); // 總碳水（含纖維）
    const carb_net  = Math.max(0, carb100 - fiber100);               // 淨碳水（已扣纖維）
    const sugar100  = carb100 * 0.038;
    const cal100    = prot100 * 4 + carb_net * 4 + fiber100 * 2 + fat100 * 9;

    // 更新營養標示表
    const s80 = 80 / 100;
    $('nt-cal').textContent     = cal100.toFixed(1);
    $('nt-cal8').textContent    = (cal100 * s80).toFixed(1);
    $('nt-prot').textContent    = prot100.toFixed(1);
    $('nt-prot8').textContent   = (prot100 * s80).toFixed(1);
    // 同步「預估乾麵蛋白質」——與營養標示同源，精確版
    $('sv-dry-prot').textContent = prot100.toFixed(1) + ' g/100g';
    // 同步顯示實際蒸發倍數（prot100 / 濕基蛋白質目標）
    const actualEvap = protTarget > 0 ? prot100 / protTarget : 1.3;
    $('sv-evap-factor').textContent = actualEvap.toFixed(2) + '× (實際)';
    $('nt-fat').textContent     = fat100.toFixed(1);
    $('nt-fat8').textContent    = (fat100 * s80).toFixed(1);
    $('nt-carb').textContent    = carb100.toFixed(1);
    $('nt-carb8').textContent   = (carb100 * s80).toFixed(1);
    $('nt-sugar').textContent   = sugar100.toFixed(1);
    $('nt-sugar8').textContent  = (sugar100 * s80).toFixed(1);
    $('nt-fiber').textContent   = fiber100.toFixed(1);
    $('nt-fiber8').textContent  = (fiber100 * s80).toFixed(1);
    $('nt-sodium').textContent  = sodium100.toFixed(0);
    $('nt-sodium8').textContent = (sodium100 * s80).toFixed(0);
  }

  // ── 成本計算 ────────────────────────────────────────────
  const ndWeight  = slVal('nd-weight');
  const yieldLoss = slVal('yield-loss') / 100;
  $('sv-yield-loss').textContent = slVal('yield-loss') + '%';

  // pm-ratio：由配方總表自動連動
  let actualPmRatio;
  if (formula) {
    const P    = formula.P;
    const bF   = slVal('batch-flour') || 1000;
    const C312x  = ckEn('en-312f') ? slVal('amt-312f') : 0;
    const C7000x = ckEn('en-7000') ? slVal('amt-7000') : 0;
    const batchSalt = bF * slVal('salt-f') / 100;
    const dryTotal  = P + bF + C312x + C7000x + batchSalt;
    actualPmRatio = dryTotal > 0 ? P / dryTotal * 100 : 0;
  } else {
    actualPmRatio = slVal('pm-ratio');
  }
  $('sv-pm-ratio').textContent = actualPmRatio.toFixed(1) + '%';
  $('pm-ratio').value = Math.min(70, Math.round(actualPmRatio));

  const pmKg   = (ndWeight * actualPmRatio / 100) / 1000;
  const cIng   = pmKg * pm.costPerKg * (1 + yieldLoss);
  const cPmMfg = pmKg * slVal('pm-mfg') * (1 + yieldLoss);
  const ndBundlesC = +(($('nd-bundles') && $('nd-bundles').value) || 6);
  const cNdMfg_b1 = slVal('nd-mfg') * 1;          // 看板1：單塊麵體
  const cNdMfg_b2 = slVal('nd-mfg') * ndBundlesC; // 看板2：每包 n 束
  const cBag   = slVal('nd-bag');
  const cSauce = ckEn('ck-sauce') ? slVal('sauce-cost') : 0;
  const cBox   = slVal('box-cost') / (slVal('box-qty') || 12);

  // 纖維食材成本（按每包乾麵克數中纖維佔比計）
  let cFiber = 0;
  if (formula) {
    const bF2  = slVal('batch-flour') || 1000;
    const C312x  = ckEn('en-312f') ? slVal('amt-312f') : 0;
    const C7000x = ckEn('en-7000') ? slVal('amt-7000') : 0;
    const bSalt2 = bF2 * slVal('salt-f') / 100;
    const dryTot2 = formula.P + bF2 + C312x + C7000x + bSalt2;
    if (dryTot2 > 0) {
      const perPack312  = C312x  / dryTot2 * ndWeight / 1000 * slVal('312f-p');
      const perPack7000 = C7000x / dryTot2 * ndWeight / 1000 * slVal('7000-p');
      cFiber = (perPack312 + perPack7000) * (1 + yieldLoss);
    }
  }

  // 看板1 每包總成本（單塊）
  const totalCost = cIng + cPmMfg + cNdMfg_b1 + cBag + cSauce + cBox + cFiber;
  // 成本面板顯示：依目前 activeBoard 選擇代工費
  const cNdMfg_disp = activeBoard === 1 ? cNdMfg_b1 : cNdMfg_b2;

  $('c-ing').textContent    = cIng.toFixed(2)    + ' 元';
  $('c-pm-mfg').textContent = cPmMfg.toFixed(2)  + ' 元';
  $('c-nd-mfg').textContent = cNdMfg_disp.toFixed(2) + ' 元';
  $('c-bag').textContent    = cBag.toFixed(2)     + ' 元';
  $('c-sauce').textContent  = cSauce.toFixed(2)   + ' 元';
  $('c-box').textContent    = cBox.toFixed(2)     + ' 元';
  if ($('c-fiber')) $('c-fiber').textContent = cFiber.toFixed(2) + ' 元';
  $('c-total').textContent  = totalCost.toFixed(2) + ' 元';

  // ── 看板2 成本（無醬料，× ndBundles 束/包） ─────────────────
  const b2PackCost    = cIng + cPmMfg + cNdMfg_b2 + cBag + cBox + cFiber;
  const b2BundleCost  = b2PackCost * 6;
  $('b2-pack-cost').textContent         = b2PackCost.toFixed(2)   + ' 元';
  $('b2-bundle-total-cost').textContent = b2BundleCost.toFixed(2) + ' 元';

  // ── 看板1 定價分析 ───────────────────────────────────────
  const price = slVal('sell-price');
  $('sv-price').textContent = price + ' 元';
  const fee = feeCalc(price);
  $('fee-shopee-amt').textContent = ckEn('ck-shopee') ? `-${fee.shopee.toFixed(1)}元` : '';
  $('fee-ads-amt').textContent    = ckEn('ck-ads')    ? `-${fee.ads.toFixed(1)}元`    : '';
  $('fee-tax-amt').textContent    = `-${(price / 1.05 * 0.05).toFixed(1)}元`;

  const netCash   = fee.net;
  const profit1   = netCash - totalCost;
  const profRate  = price > 0 ? (profit1 / price * 100) : 0;
  const deductRate = (ckEn('ck-shopee') ? 0.125 : 0) + (1/1.05*0.05) + (ckEn('ck-ads') ? 0.22 : 0);
  const beven     = (1 - deductRate) > 0 ? totalCost / (1 - deductRate) : 9999;

  $('net-cash').textContent    = netCash.toFixed(2)   + ' 元';
  $('pr-cost').textContent     = totalCost.toFixed(2) + ' 元';
  $('net-profit').textContent  = profit1.toFixed(2)   + ' 元';
  $('net-profit').style.color  = profit1 >= 0 ? 'var(--green)' : 'var(--red)';
  $('profit-rate').textContent = profRate.toFixed(1)  + '%';
  $('breakeven').textContent   = Math.ceil(beven)     + ' 元';

  // 費用比例條（看板1）
  const pBase = price > 0 ? price : 1;
  const setBar = (id, w, txt) => {
    const el = $(id);
    el.style.width   = Math.max(0, w / pBase * 100) + '%';
    el.textContent   = w > 2 ? txt : '';
  };
  setBar('fb-cost',   totalCost,                     `成本${totalCost.toFixed(0)}`);
  setBar('fb-shop',   fee.shopee,                    `蝦${fee.shopee.toFixed(0)}`);
  setBar('fb-tax',    price / 1.05 * 0.05,           `稅${(price/1.05*0.05).toFixed(0)}`);
  setBar('fb-ads',    fee.ads,                       `廣${fee.ads.toFixed(0)}`);
  setBar('fb-profit', Math.max(0, profit1),          `利${profit1.toFixed(0)}`);

  // 三個比價卡（看板1）
  [[50,'p50','pc50'],[60,'p60','pc60'],[80,'p80','pc80']].forEach(([sp, pid, cid]) => {
    const f  = feeCalc(sp);
    const pr = f.net - totalCost;
    $(pid + 'n').textContent = pr.toFixed(1) + ' 元';
    $(pid + 'n').style.color = pr >= 0 ? 'var(--green)' : 'var(--red)';
    $(pid + 's').textContent = pr >= 0 ? '✓ 獲利' : '✗ 虧損';
    $(pid + 's').style.color = pr >= 0 ? 'var(--green)' : 'var(--red)';
    $(cid).style.borderColor = pr >= 0 ? 'var(--green)' : 'var(--red)';
  });

  // 建議框（看板1）
  const abox = $('advice-box');
  if (profit1 < 0) {
    abox.innerHTML = `<div class="alert-box" style="background:rgba(255,92,92,.1);border-color:var(--red);color:var(--red);">⚠ 當前定價低於損益平衡點 ${Math.ceil(beven)} 元，建議調高售價或降低成本。</div>`;
  } else if (profRate < 20) {
    abox.innerHTML = `<div class="alert-box" style="background:rgba(255,211,61,.08);border-color:var(--yellow);color:var(--yellow);">💡 淨利率 ${profRate.toFixed(1)}%，建議目標 30% 以上。損益平衡 ${Math.ceil(beven)} 元。</div>`;
  } else {
    abox.innerHTML = `<div class="alert-box" style="background:rgba(34,211,160,.08);border-color:var(--green);color:var(--green);">✓ 淨利率 ${profRate.toFixed(1)}%，健康獲利！損益平衡 ${Math.ceil(beven)} 元。</div>`;
  }

  // ── 看板2 定價分析 ───────────────────────────────────────
  const bundlePrice = slVal('bundle-price');
  $('sv-bundle-price').textContent = bundlePrice.toLocaleString() + ' 元';
  const f2 = feeCalcB2(bundlePrice);
  $('fee-shopee-b2').textContent = ckEn('ck-shopee-b2') ? `-${f2.shopee.toFixed(0)}元` : '';
  $('fee-ads-b2').textContent    = ckEn('ck-ads-b2')    ? `-${f2.ads.toFixed(0)}元`    : '';
  $('fee-tax-b2').textContent    = `-${(bundlePrice / 1.05 * 0.05).toFixed(0)}元`;

  const b2NetCash  = f2.net;
  const b2Profit   = b2NetCash - b2BundleCost;
  const b2ProfRate = bundlePrice > 0 ? (b2Profit / bundlePrice * 100) : 0;
  const dr2        = (ckEn('ck-shopee-b2')?0.125:0) + (1/1.05*0.05) + (ckEn('ck-ads-b2')?0.22:0);
  const b2BEven    = (1 - dr2) > 0 ? b2BundleCost / (1 - dr2) : 9999;

  $('b2-net-cash').textContent    = b2NetCash.toFixed(0)     + ' 元';
  $('b2-bundle-cost').textContent = b2BundleCost.toFixed(2)  + ' 元';
  $('b2-net-profit').textContent  = b2Profit.toFixed(2)      + ' 元';
  $('b2-net-profit').style.color  = b2Profit >= 0 ? 'var(--green)' : 'var(--red)';
  $('b2-profit-rate').textContent = b2ProfRate.toFixed(1)    + '%';
  $('b2-per-pack').textContent    = (bundlePrice / 6).toFixed(0)  + ' 元/包';
  $('b2-per-serving').textContent = (bundlePrice / 36).toFixed(1) + ' 元/份';
  $('b2-breakeven').textContent   = Math.ceil(b2BEven)       + ' 元';

  // 費用比例條（看板2）
  const bp = bundlePrice > 0 ? bundlePrice : 1;
  const sb2 = (id, w, txt) => {
    const el = $(id);
    el.style.width = Math.max(0, w / bp * 100) + '%';
    el.textContent = w > 10 ? txt : '';
  };
  sb2('fb2-cost',   b2BundleCost,              `成本${b2BundleCost.toFixed(0)}`);
  sb2('fb2-shop',   f2.shopee,                 `蝦${f2.shopee.toFixed(0)}`);
  sb2('fb2-tax',    bundlePrice / 1.05 * 0.05, `稅${(bundlePrice/1.05*0.05).toFixed(0)}`);
  sb2('fb2-ads',    f2.ads,                    `廣${f2.ads.toFixed(0)}`);
  sb2('fb2-profit', Math.max(0, b2Profit),     `利${b2Profit.toFixed(0)}`);

  // 三個比價卡（看板2）
  [[1199,'b2p1','b2pc1'],[1499,'b2p2','b2pc2'],[1799,'b2p3','b2pc3']].forEach(([sp, pid, cid]) => {
    const f  = feeCalcB2(sp);
    const pr = f.net - b2BundleCost;
    $(pid + 'n').textContent = pr.toFixed(0) + ' 元';
    $(pid + 'n').style.color = pr >= 0 ? 'var(--green)' : 'var(--red)';
    $(pid + 's').textContent = pr >= 0 ? '✓ 獲利' : '✗ 虧損';
    $(pid + 's').style.color = pr >= 0 ? 'var(--green)' : 'var(--red)';
    $(cid).style.borderColor = pr >= 0 ? 'var(--green)' : 'var(--red)';
  });

  // 建議框（看板2）
  const ab2 = $('b2-advice-box');
  if (b2Profit < 0) {
    ab2.innerHTML = `<div class="alert-box" style="background:rgba(255,92,92,.1);border-color:var(--red);color:var(--red);">⚠ 組合定價低於損益平衡 ${Math.ceil(b2BEven)} 元，建議調高售價。</div>`;
  } else if (b2ProfRate < 20) {
    ab2.innerHTML = `<div class="alert-box" style="background:rgba(255,211,61,.08);border-color:var(--yellow);color:var(--yellow);">💡 淨利率 ${b2ProfRate.toFixed(1)}%，建議目標30%+。損益平衡 ${Math.ceil(b2BEven)} 元。</div>`;
  } else {
    ab2.innerHTML = `<div class="alert-box" style="background:rgba(34,211,160,.08);border-color:var(--green);color:var(--green);">✓ 淨利率 ${b2ProfRate.toFixed(1)}%，健康獲利！損益平衡 ${Math.ceil(b2BEven)} 元。</div>`;
  }
}

// ── 頁面切換（含第3頁行銷文件） ────────────────────────────
function switchPage(n) {
  $('page1').style.display = n === 1 ? '' : 'none';
  $('page2').style.display = n === 2 ? '' : 'none';
  $('page3').style.display = n === 3 ? '' : 'none';
  document.querySelectorAll('.tab-btn').forEach((b, i) =>
    b.classList.toggle('active', i === n - 1)
  );
  if (n === 3) {
    renderMktSegments();
    renderChecklist();
    renderPlan(activePlan);
  }
}

// ── 看板切換 ────────────────────────────────────────────────
function switchBoard(n) {
  activeBoard = n;
  $('board1-pricing').style.display = n === 1 ? '' : 'none';
  $('board2-pricing').style.display = n === 2 ? '' : 'none';
  $('b2-cost-card').style.display   = n === 2 ? '' : 'none';
  // 只切換頂部兩個看板切換按鈕，不影響 page3 的方案按鈕
  const boardTabs = document.querySelector('.board-tabs');
  if (boardTabs) {
    boardTabs.querySelectorAll('.board-tab-btn').forEach((b, i) =>
      b.classList.toggle('active', i === n - 1)
    );
  }
  $('ck-sauce').checked = (n === 1);
  $('sauce-sg').style.opacity = (n === 1) ? '1' : '.35';
  calc();
}

// ── Excel 匯出 ──────────────────────────────────────────────
function exportExcel() {
  const wb = XLSX.utils.book_new();

  // Sheet 1: 定價分析
  const ws1 = XLSX.utils.aoa_to_sheet([
    ['NoodleNoodle 高蛋白纖維麵 決策系統 v4'],
    ['匯出日期', new Date().toLocaleDateString('zh-TW')],
    [],
    ['【看板1 · 風味麵（含醬包）】'],
    ['售價', $('sv-price').textContent, '每包總成本', $('c-total').textContent],
    ['扣費後現金回流', $('net-cash').textContent, '每包淨利潤', $('net-profit').textContent],
    ['淨利率', $('profit-rate').textContent, '損益平衡最低售價', $('breakeven').textContent],
    [],
    ['【看板2 · 純麵6包組（無醬包）】'],
    ['組合售價', $('sv-bundle-price').textContent, '6包組合總成本', $('b2-bundle-total-cost').textContent],
    ['整組淨利潤', $('b2-net-profit').textContent, '淨利率', $('b2-profit-rate').textContent],
    ['損益平衡', $('b2-breakeven').textContent, '等效每包售價', $('b2-per-pack').textContent],
  ]);
  XLSX.utils.book_append_sheet(wb, ws1, '定價分析');

  // Sheet 2: 成本結構
  const ws2 = XLSX.utils.aoa_to_sheet([
    ['項目', '金額（元）'],
    ['預拌粉食材', $('c-ing').textContent],
    ['預拌粉代工', $('c-pm-mfg').textContent],
    ['麵塊代工',   $('c-nd-mfg').textContent],
    ['麵體包裝袋', $('c-bag').textContent],
    ['醬料',       $('c-sauce').textContent],
    ['紙箱分攤',   $('c-box').textContent],
    ['纖維添加物', $('c-fiber') ? $('c-fiber').textContent : '0'],
    ['每包總成本', $('c-total').textContent],
  ]);
  XLSX.utils.book_append_sheet(wb, ws2, '成本結構');

  // Sheet 3: 配方總表
  const rows = Array.from(document.querySelectorAll('#formula-tbody tr'));
  const ws3data = [['成分', '重量(g)', '烘焙百分比', '佔濕麵糰%', '蛋白質(g)', '纖維(g)']];
  rows.forEach(r => {
    const cells = Array.from(r.querySelectorAll('td'))
      .map(c => c.textContent.trim().split('\n')[0]);
    ws3data.push(cells);
  });
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(ws3data), '配方總表');

  // Sheet 4: 營養標示
  const ws4 = XLSX.utils.aoa_to_sheet([
    ['營養素', '每100g乾麵', '每份(80g)'],
    ['熱量 kcal',  $('nt-cal').textContent,    $('nt-cal8').textContent],
    ['蛋白質 g',   $('nt-prot').textContent,   $('nt-prot8').textContent],
    ['脂肪 g',     $('nt-fat').textContent,    $('nt-fat8').textContent],
    ['碳水化合物 g', $('nt-carb').textContent,  $('nt-carb8').textContent],
    ['　糖 g',        $('nt-sugar').textContent, $('nt-sugar8').textContent],
    ['膳食纖維 g',    $('nt-fiber').textContent, $('nt-fiber8').textContent],
    ['鈉 mg',         $('nt-sodium').textContent,$('nt-sodium8').textContent],
  ]);
  XLSX.utils.book_append_sheet(wb, ws4, '營養標示');
  XLSX.writeFile(wb, 'NoodleNoodle決策分析.xlsx');
}

calc();
