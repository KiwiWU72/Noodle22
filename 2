<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NoodleNoodle 高蛋白纖維麵 決策系統 v4</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root{
  --bg:#0f1117;--card:#1a1d27;--card2:#22263a;
  --accent:#6c63ff;--a2:#f7971e;
  --green:#22d3a0;--red:#ff5c5c;--yellow:#ffd93d;
  --text:#e8eaed;--t2:#9aa0b4;--border:#2d3150;
  --gold:#e8b84b;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'Segoe UI',system-ui,sans-serif;padding:14px 12px 60px;}

/* ── Header ── */
.hdr{text-align:center;margin-bottom:12px;}
h1{font-size:1.65rem;font-weight:900;background:linear-gradient(135deg,#6c63ff,#f7971e);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.subtitle{font-size:.78rem;color:var(--t2);margin:2px 0 9px;}
.tab-bar{display:flex;justify-content:center;align-items:center;gap:7px;flex-wrap:wrap;}
.tab-btn{padding:6px 16px;border-radius:18px;border:1.5px solid var(--border);
  background:transparent;color:var(--t2);cursor:pointer;font-size:.8rem;font-weight:600;font-family:inherit;transition:all .18s;}
.tab-btn.active{background:var(--accent);border-color:var(--accent);color:#fff;}
.export-btn{padding:6px 16px;border-radius:18px;border:1.5px solid var(--a2);
  background:rgba(247,151,30,.15);color:var(--a2);cursor:pointer;font-size:.8rem;font-weight:700;font-family:inherit;transition:all .18s;}
.export-btn:hover{background:var(--a2);color:#000;}

/* ── Board sub-tabs ── */
.board-tabs{display:flex;gap:7px;margin-bottom:11px;flex-wrap:wrap;}
.board-tab-btn{padding:7px 20px;border-radius:20px;border:1.5px solid var(--border);
  background:transparent;color:var(--t2);cursor:pointer;font-size:.82rem;font-weight:700;font-family:inherit;transition:all .18s;}
.board-tab-btn.b1.active{background:var(--accent);border-color:var(--accent);color:#fff;box-shadow:0 0 14px rgba(108,99,255,.35);}
.board-tab-btn.b2.active{background:var(--a2);border-color:var(--a2);color:#000;box-shadow:0 0 14px rgba(247,151,30,.35);}

/* ── Layout ── */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-top:11px;}
.card{background:var(--card);border:1px solid var(--border);border-radius:13px;padding:15px;}
.card-full{background:var(--card);border:1px solid var(--border);border-radius:13px;padding:15px;margin-bottom:11px;}

/* Formula card — gold accent */
.formula-card{background:var(--card);border:2px solid var(--gold);border-radius:14px;padding:16px;margin-bottom:11px;
  box-shadow:0 0 24px rgba(232,184,75,.12);}
.formula-title{font-size:1rem;font-weight:800;color:var(--gold);margin-bottom:13px;
  padding-bottom:10px;border-bottom:1px solid rgba(232,184,75,.3);display:flex;align-items:center;gap:8px;}

.card-title{font-size:.88rem;font-weight:700;color:var(--accent);margin-bottom:11px;
  padding-bottom:8px;border-bottom:1px solid var(--border);}
.sec-lbl{font-size:.67rem;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:1.1px;margin:9px 0 6px;}
.divider{height:1px;background:var(--border);margin:9px 0;}
.sub-panel{background:var(--card2);border-radius:8px;padding:10px 12px;margin-top:7px;}

/* ── Sliders ── */
.sg{margin-bottom:10px;}
.sl{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;}
.sn{font-size:.79rem;color:var(--t2);}
.sv{font-size:.8rem;font-weight:700;min-width:68px;text-align:right;}
input[type=range]{width:100%;height:5px;border-radius:3px;appearance:none;-webkit-appearance:none;
  background:var(--border);outline:none;cursor:pointer;}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:15px;height:15px;border-radius:50%;
  background:var(--accent);cursor:pointer;box-shadow:0 0 5px rgba(108,99,255,.45);}
input[type=range]:disabled{opacity:.3;cursor:default;}
input[type=range]:disabled::-webkit-slider-thumb{background:var(--t2);}
/* Price sliders — orange accent */
input[type=range].price-sl::-webkit-slider-thumb{background:var(--a2);box-shadow:0 0 5px rgba(247,151,30,.45);}
input[type=range].price-sl::-webkit-slider-runnable-track{background:rgba(247,151,30,.18);}

/* ── Checkboxes ── */
input[type=checkbox]{width:15px;height:15px;cursor:pointer;accent-color:var(--accent);}
.ck-row{display:flex;align-items:center;gap:7px;margin-bottom:4px;}
.ck-label{font-size:.81rem;cursor:pointer;}

/* ── Ingredient blocks ── */
.ing-block{border:1px solid var(--border);border-radius:8px;padding:9px 11px;margin-bottom:7px;transition:opacity .2s;}
.ing-block.disabled{opacity:.38;}
.ing-header{display:flex;align-items:center;gap:7px;margin-bottom:5px;}
.ing-name-input{background:var(--card2);border:1px solid var(--border);border-radius:5px;
  color:var(--text);padding:2px 6px;font-size:.78rem;width:105px;font-family:inherit;}
.ing-sliders{display:grid;grid-template-columns:1fr 1fr;gap:7px;}

/* ── Ratio bar ── */
.ratio-bar{display:flex;height:7px;border-radius:4px;overflow:hidden;margin:5px 0 2px;}
.rseg{height:100%;transition:width .3s;}

/* ── Formula Table ── */
.ftable{width:100%;border-collapse:collapse;font-size:.79rem;margin-top:10px;}
.ftable thead tr{background:#1b1e2e;}
.ftable th{padding:7px 9px;text-align:left;font-weight:700;font-size:.72rem;color:var(--gold);border-bottom:2px solid rgba(232,184,75,.3);}
.ftable td{padding:5px 9px;border-bottom:1px solid var(--border);vertical-align:top;}
.ftable tr:last-child td{border-bottom:none;}
.ftable tr.total-row{background:rgba(232,184,75,.08);font-weight:700;}
.ftable tr.total-row td{border-top:2px solid var(--gold);color:var(--gold);}
.ftable tr.flour-row td{color:#a0c4ff;}
.ftable tr.fiber-row td{color:var(--green);}
.ftable tr.water-row td{color:#7dd3fc;}
.ftable tr.salt-row td{color:var(--t2);}
.ftable tr.ing-row td{color:var(--text);}
.gram-num{font-weight:700;font-size:.85rem;}
.qc-bar{display:flex;gap:16px;flex-wrap:wrap;margin-top:10px;padding:10px 14px;
  background:rgba(232,184,75,.06);border:1px solid rgba(232,184,75,.25);border-radius:8px;}
.qc-item{font-size:.9rem;}
.qc-big{font-size:1.05rem;font-weight:800;}
.qc-ok{color:var(--green);}
.qc-warn{color:var(--yellow);}
.qc-bad{color:var(--red);}

/* ── Fiber type boxes ── */
.fiber-box{border:1.5px solid var(--border);border-radius:8px;padding:9px 11px;margin-bottom:7px;transition:all .2s;}
.fiber-box.active{border-color:var(--green);}
.fiber-box.disabled{opacity:.35;}
.fiber-header{display:flex;align-items:center;gap:8px;margin-bottom:4px;}
.fiber-tag{display:inline-block;padding:1px 7px;border-radius:10px;font-size:.68rem;font-weight:700;}
.tag-fiber{background:rgba(34,211,160,.15);color:var(--green);}
.tag-prot{background:rgba(108,99,255,.15);color:var(--accent);}
.tag-ph-warn{background:rgba(255,92,92,.15);color:var(--red);}
.tag-ph-ok{background:rgba(34,211,160,.15);color:var(--green);}

/* ── Nutrition table ── */
.nutr-table{width:100%;border-collapse:collapse;font-size:.76rem;margin-top:7px;}
.nutr-table th{background:#1e2235;padding:5px 7px;text-align:left;font-weight:600;font-size:.7rem;color:var(--t2);}
.nutr-table td{padding:4px 7px;border-bottom:1px solid var(--border);}
.nutr-table tr:last-child td{border-bottom:none;}

/* ── Metrics ── */
.mrow{display:flex;justify-content:space-between;align-items:center;
  padding:6px 0;border-bottom:1px solid var(--border);font-size:.82rem;}
.mrow:last-child{border-bottom:none;}
.mval{font-weight:700;}
.big{font-size:1.25rem;font-weight:800;}
.xl{font-size:1.6rem;font-weight:900;}
.green{color:var(--green);}
.red{color:var(--red);}
.yellow{color:var(--yellow);}

/* ── Fee bar ── */
.fee-bar{display:flex;height:33px;border-radius:7px;overflow:hidden;margin:8px 0;}
.fseg{display:flex;align-items:center;justify-content:center;font-size:.67rem;font-weight:700;
  transition:width .3s;overflow:hidden;white-space:nowrap;}

/* ── Protein bar ── */
.prot-wrap{height:22px;background:var(--border);border-radius:11px;overflow:hidden;margin:6px 0 3px;}
.prot-fill{height:100%;border-radius:11px;transition:width .3s,background .3s;}

/* ── Sauce buttons ── */
.sauce-row{display:flex;flex-wrap:wrap;gap:5px;margin-top:6px;}
.sbtn{padding:4px 9px;border-radius:16px;border:1.5px solid var(--border);
  background:transparent;color:var(--t2);cursor:pointer;font-size:.72rem;font-weight:600;font-family:inherit;transition:all .18s;}
.sbtn.active{border-color:var(--accent);background:rgba(108,99,255,.18);color:var(--text);}

/* ── Alert ── */
.alert{border-radius:8px;padding:8px 11px;font-size:.79rem;line-height:1.65;margin-top:8px;}
.alert-red{background:rgba(255,92,92,.1);border:1px solid rgba(255,92,92,.35);}
.alert-yellow{background:rgba(255,217,61,.1);border:1px solid rgba(255,217,61,.35);}
.alert-green{background:rgba(34,211,160,.1);border:1px solid rgba(34,211,160,.35);}

/* ── Number input ── */
input[type=number]{background:var(--card2);border:1.5px solid var(--border);border-radius:6px;
  color:var(--text);padding:3px 6px;width:65px;font-size:.84rem;text-align:center;font-family:inherit;outline:none;}
input[type=number]:focus{border-color:var(--accent);}
.inline-f{display:flex;align-items:center;gap:8px;margin-bottom:9px;}
.inline-f .lbl{font-size:.79rem;color:var(--t2);flex:1;}

/* ── Flour selector ── */
.flour-select{background:var(--card2);border:1.5px solid var(--border);border-radius:7px;
  color:var(--text);padding:4px 8px;font-size:.8rem;font-family:inherit;outline:none;cursor:pointer;width:100%;}
.flour-select:focus{border-color:var(--gold);}

/* ── 3-price cards ── */
.price3{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-bottom:10px;}
.p3card{background:var(--card2);border-radius:8px;padding:10px;text-align:center;
  border:1.5px solid var(--border);transition:border-color .3s;}
.p3card.hl{border-color:var(--accent);}
.p3lbl{font-size:.68rem;color:var(--t2);margin-bottom:3px;}
.p3num{font-size:1.25rem;font-weight:800;}
.p3st{font-size:.67rem;margin-top:3px;}

/* ── Legend ── */
.legend{display:flex;gap:8px;flex-wrap:wrap;font-size:.68rem;margin-bottom:3px;}
.ldot{width:8px;height:8px;border-radius:2px;display:inline-block;margin-right:2px;}

/* ══════ PAGE 2 ══════ */
#page2{max-width:860px;margin:0 auto;}
.doc-card{background:var(--card);border:1px solid var(--border);border-radius:13px;padding:26px 28px;line-height:1.85;}
.doc-card h2{font-size:1.08rem;font-weight:800;color:var(--accent);margin:20px 0 9px;border-left:3px solid var(--accent);padding-left:9px;}
.doc-card h3{font-size:.96rem;font-weight:700;color:var(--a2);margin:16px 0 7px;}
.doc-card p{font-size:.86rem;margin-bottom:9px;}
.doc-card ul{padding-left:18px;margin-bottom:9px;}
.doc-card li{font-size:.84rem;margin-bottom:4px;}
.doc-card .math{font-style:italic;color:var(--yellow);}
.doc-card .chem{font-family:monospace;color:var(--green);font-size:.88rem;}
.sop-block{background:#0a0c14;border:1px solid var(--border);border-radius:7px;
  padding:13px 16px;font-family:monospace;font-size:.78rem;line-height:1.7;color:#a8d8a8;margin:10px 0;white-space:pre-wrap;}
.doc-card .tag-label{display:inline-block;padding:1px 7px;border-radius:10px;font-size:.7rem;font-weight:700;
  background:rgba(34,211,160,.15);color:var(--green);margin-left:5px;}
.callout{background:rgba(108,99,255,.1);border:1px solid rgba(108,99,255,.3);border-radius:8px;padding:11px 14px;margin:10px 0;font-size:.83rem;}
.danger-callout{background:rgba(255,92,92,.1);border:1px solid rgba(255,92,92,.35);border-radius:8px;padding:11px 14px;margin:10px 0;font-size:.83rem;}
.compare-table{width:100%;border-collapse:collapse;font-size:.8rem;margin-top:7px;}
.compare-table th{background:#1b1e2e;padding:7px 9px;text-align:left;font-weight:600;color:var(--t2);}
.compare-table td{padding:6px 9px;border-bottom:1px solid var(--border);}

@media(max-width:800px){
  .two-col{grid-template-columns:1fr;}
  .price3{grid-template-columns:repeat(3,1fr);}
  .doc-card{padding:16px 14px;}
  .ing-sliders{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<!-- ══ HEADER ══ -->
<div class="hdr">
  <h1>🍜 NoodleNoodle 高蛋白纖維麵</h1>
  <p class="subtitle">創業決策系統 v4 · 配方 × 成本 × 定價 × 技術</p>
  <div class="tab-bar">
    <button class="tab-btn active" onclick="switchPage(1)">📊 決策看板</button>
    <button class="tab-btn" onclick="switchPage(2)">🔬 技術文件</button>
    <button class="tab-btn" onclick="switchPage(3)">📣 行銷文件</button>
    <button class="export-btn" onclick="exportExcel()">⬇ 匯出 Excel</button>
  </div>
</div>

<!-- ══════════════════════ PAGE 1 ══════════════════════ -->
<div id="page1">

<!-- Board sub-tabs -->
<div class="board-tabs">
  <button class="board-tab-btn b1 active" onclick="switchBoard(1)">📦 看板1 · 風味麵（含醬包）</button>
  <button class="board-tab-btn b2" onclick="switchBoard(2)">🍜 看板2 · 純麵6包組（無醬包）</button>
</div>

<!-- ① 看板1 定價分析 -->
<div id="board1-pricing">
<div class="card-full">
  <div class="card-title">📈 定價分析 — 蝦皮電商通路</div>
  <div class="two-col" style="gap:14px;">
    <div>
      <div class="sec-lbl">每包售價設定</div>
      <div class="sg">
        <div class="sl"><span class="sn">💵 建議售價</span>
          <span class="sv" id="sv-price" style="font-size:1.15rem;color:var(--a2);">80 元</span></div>
        <input type="range" id="sell-price" min="30" max="200" value="80" step="5" oninput="calc()">
      </div>
      <div class="sec-lbl">通路費用（勾選 = 計入）</div>
      <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:8px;">
        <label class="ck-row">
          <input type="checkbox" id="ck-shopee" checked onchange="calc()">
          <span class="ck-label">蝦皮抽成 <strong>12.5%</strong>
            <span id="fee-shopee-amt" style="color:var(--a2);margin-left:4px;"></span></span>
        </label>
        <label class="ck-row">
          <input type="checkbox" id="ck-ads" checked onchange="calc()">
          <span class="ck-label">廣告費 <strong>22%</strong>
            <span id="fee-ads-amt" style="color:#6c63ff;margin-left:4px;"></span></span>
        </label>
        <div class="ck-row" style="opacity:.5;">
          <input type="checkbox" checked disabled>
          <span class="ck-label">營業稅 <strong>5%（內稅·固定）</strong>
            <span id="fee-tax-amt" style="color:var(--yellow);margin-left:4px;"></span></span>
        </div>
      </div>
      <div class="legend">
        <span><span class="ldot" style="background:#ff5c5c;"></span>成本</span>
        <span><span class="ldot" style="background:#f7971e;"></span>蝦皮</span>
        <span><span class="ldot" style="background:#ffd93d;"></span>稅</span>
        <span><span class="ldot" style="background:#6c63ff;"></span>廣告</span>
        <span><span class="ldot" style="background:#22d3a0;"></span>淨利</span>
      </div>
      <div class="fee-bar">
        <div id="fb-cost"   class="fseg" style="background:#ff5c5c;color:rgba(0,0,0,.7);"></div>
        <div id="fb-shop"   class="fseg" style="background:#f7971e;color:rgba(0,0,0,.7);"></div>
        <div id="fb-tax"    class="fseg" style="background:#ffd93d;color:rgba(0,0,0,.7);"></div>
        <div id="fb-ads"    class="fseg" style="background:#6c63ff;color:#fff;"></div>
        <div id="fb-profit" class="fseg" style="background:#22d3a0;color:rgba(0,0,0,.7);"></div>
      </div>
    </div>
    <div>
      <div class="sec-lbl">費用拆解 / 獲利</div>
      <div class="sub-panel">
        <div class="mrow"><span>扣費後現金回流</span><span class="mval green" id="net-cash">--</span></div>
        <div class="mrow"><span>每包總成本</span><span class="mval red" id="pr-cost">--</span></div>
        <div class="mrow" style="border-top:2px solid var(--border);padding-top:6px;margin-top:2px;">
          <span style="font-weight:700;">🎯 每包淨利潤</span>
          <span class="mval xl" id="net-profit">--</span>
        </div>
        <div class="mrow"><span>淨利率</span><span class="mval" id="profit-rate">--</span></div>
        <div class="mrow"><span>損益平衡最低售價</span><span class="mval yellow" id="breakeven">--</span></div>
      </div>
      <div class="sec-lbl" style="margin-top:10px;">三個典型售價比較</div>
      <div class="price3">
        <div class="p3card" id="pc50"><div class="p3lbl">售價 50 元</div><div class="p3num" id="p50n">--</div><div class="p3st" id="p50s"></div></div>
        <div class="p3card" id="pc60"><div class="p3lbl">售價 60 元</div><div class="p3num" id="p60n">--</div><div class="p3st" id="p60s"></div></div>
        <div class="p3card" id="pc80"><div class="p3lbl">售價 80 元</div><div class="p3num" id="p80n">--</div><div class="p3st" id="p80s"></div></div>
      </div>
      <div id="advice-box"></div>
    </div>
  </div>
</div>
</div><!-- /board1-pricing -->

<!-- ① 看板2 定價分析 -->
<div id="board2-pricing" style="display:none;">
<div class="card-full" style="border-color:rgba(247,151,30,.35);">
  <div class="card-title" style="color:var(--a2);">📈 定價分析 — 純麵6包組（無醬包）</div>
  <div style="font-size:.73rem;color:var(--t2);margin:-4px 0 12px;padding:6px 10px;background:rgba(247,151,30,.08);border-radius:6px;border:1px solid rgba(247,151,30,.2);">
    📦 6包/組 × 6束/包 = <strong style="color:var(--a2);">36人份</strong> · 預售整組定價計算
  </div>
  <div class="two-col" style="gap:14px;">
    <div>
      <div class="sec-lbl">每組售價設定</div>
      <div class="sg">
        <div class="sl"><span class="sn">💵 預售組合售價</span>
          <span class="sv" id="sv-bundle-price" style="font-size:1.15rem;color:var(--a2);">1,299 元</span></div>
        <input type="range" id="bundle-price" min="500" max="3500" value="1299" step="50" oninput="calc()">
      </div>
      <div class="sec-lbl">通路費用（勾選 = 計入）</div>
      <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:8px;">
        <label class="ck-row">
          <input type="checkbox" id="ck-shopee-b2" checked onchange="calc()">
          <span class="ck-label">蝦皮抽成 <strong>12.5%</strong>
            <span id="fee-shopee-b2" style="color:var(--a2);margin-left:4px;"></span></span>
        </label>
        <label class="ck-row">
          <input type="checkbox" id="ck-ads-b2" checked onchange="calc()">
          <span class="ck-label">廣告費 <strong>22%</strong>
            <span id="fee-ads-b2" style="color:#6c63ff;margin-left:4px;"></span></span>
        </label>
        <div class="ck-row" style="opacity:.5;">
          <input type="checkbox" checked disabled>
          <span class="ck-label">營業稅 <strong>5%（內稅·固定）</strong>
            <span id="fee-tax-b2" style="color:var(--yellow);margin-left:4px;"></span></span>
        </div>
      </div>
      <div class="legend">
        <span><span class="ldot" style="background:#ff5c5c;"></span>成本</span>
        <span><span class="ldot" style="background:#f7971e;"></span>蝦皮</span>
        <span><span class="ldot" style="background:#ffd93d;"></span>稅</span>
        <span><span class="ldot" style="background:#6c63ff;"></span>廣告</span>
        <span><span class="ldot" style="background:#22d3a0;"></span>淨利</span>
      </div>
